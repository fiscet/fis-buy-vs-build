# ─────────────────────────────────────────────────────────────
# Build vs Buy — environment variables
# Copy to .env.local and fill in. NEVER commit real keys.
# ─────────────────────────────────────────────────────────────

# --- LLM (runtime generateObject call, via Groq) ---
# We call Groq directly: its LPU inference returns the full structured report in
# ~3-4s, which is what makes the <5s UX budget achievable. (Anthropic models via
# OpenRouter measured 15-37s — too slow for this tool.)
GROQ_API_KEY=
# Model id for the structured generation call. Must support structured output.
#   openai/gpt-oss-120b   (default: fast + high quality)
#   llama-3.3-70b-versatile / qwen/qwen3-32b  (alternatives)
GROQ_MODEL=openai/gpt-oss-120b
# Reasoning effort for gpt-oss (low|medium|high). "low" => full report ~2.7s;
# higher levels emit far more reasoning tokens and blow the 5s budget.
GROQ_REASONING_EFFORT=low

# --- Turso (lead storage — durable, critical) ---
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Resend (sends full report by email) ---
RESEND_API_KEY=
# Verified sender address, e.g. "Build vs Buy <report@tuodominio.it>"
RESEND_FROM=

# --- Upstash Redis (rate limiting — 3 free uses before email gate) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Cron / KB refresh (phase 7 — search API, not needed for phases 1-6) ---
# Choose a search API later (Tavily / Serper / Exa); leave blank for now.
TAVILY_API_KEY=
SERPER_API_KEY=
# Secret used to authorize the Vercel cron endpoint.
CRON_SECRET=

# --- Optional: direct provider keys (experimentation / fallback only) ---
# Not used by the app today — it talks to models through OpenRouter. Kept here
# so they can be wired in if we ever bypass the gateway for a specific provider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_KEY=
