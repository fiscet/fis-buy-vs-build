# ─────────────────────────────────────────────────────────────
# Build vs Buy — environment variables
# Copy to .env.local and fill in. NEVER commit real keys.
# ─────────────────────────────────────────────────────────────

# --- LLM (runtime generateObject call, via OpenRouter) ---
# OpenRouter is OpenAI-compatible and lets us swap models without code changes.
OPENROUTER_API_KEY=
# Model id used for the single structured generation call.
# Must support structured output / tool calling. Good options:
#   anthropic/claude-haiku-4.5   (default: fast + cheap)
#   openai/gpt-4o-mini
#   google/gemini-2.0-flash
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# --- Turso (lead storage — durable, critical) ---
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Resend (sends full report by email) ---
RESEND_API_KEY=
# Verified sender address, e.g. "Build vs Buy <report@tuodominio.it>"
RESEND_FROM=

# --- Upstash Redis (rate limiting — 3 free uses before email gate) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Cron / KB refresh (phase 7 — search API, not needed for phases 1-6) ---
# Choose Tavily or Exa later; leave blank for now.
TAVILY_API_KEY=
# Secret used to authorize the Vercel cron endpoint.
CRON_SECRET=
