# ─────────────────────────────────────────────────────────────
# Build vs Buy — environment variables
# Copy to .env.local and fill in. NEVER commit real keys.
# ─────────────────────────────────────────────────────────────

# --- LLM: report generation (OpenAI, quality-critical) ---
# gpt-4.1 gave the best reasoning quality in our bake-off (~14s). The <5s target
# was relaxed in favour of analysis quality for this case.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1

# --- LLM: classification (Groq, fast + cheap) ---
# Picks 1 of 5 category ids in ~150ms. Doesn't need a reasoning model.
GROQ_API_KEY=
GROQ_CLASSIFIER_MODEL=llama-3.1-8b-instant
# Prompt-injection gate (Groq Llama Prompt Guard 2), runs before generation.
# Returns a probability in [0,1]; we block at/above the threshold. ~100ms.
GROQ_GUARD_MODEL=meta-llama/llama-prompt-guard-2-86m
PROMPT_GUARD_THRESHOLD=0.8

# --- Turso (lead storage + rate limiting / free-use gate — durable, critical) ---
# Also backs rate limiting and the 2-free-uses email gate (no separate Redis).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Resend (sends full report by email) ---
RESEND_API_KEY=
# Verified sender address, e.g. "Sviluppa o Compra <report@tuodominio.it>"
RESEND_FROM=

# --- Cron / KB refresh (phase 7) ---
# Web search for the monthly KB refresh. Exa: 1000 req/month free, ample for us.
EXA_API_KEY=
# Secret used to authorize the Vercel cron endpoint (sent as Bearer token).
CRON_SECRET=

# --- Optional: alternative provider keys (experimentation only, unused) ---
# Kept for quick model bake-offs. Anthropic/Gemini benchmarked worse on latency
# for this task; not wired into the app.
ANTHROPIC_API_KEY=
GEMINI_KEY=
